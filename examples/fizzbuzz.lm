// FizzBuzz, 1..=20. Demonstrates `if`/`else if` chains, the remainder
// operator, and both string and integer output.

fn main() {
    let mut i = 1;
    while i <= 20 {
        if i % 15 == 0 {
            print_str("FizzBuzz");
        } else if i % 3 == 0 {
            print_str("Fizz");
        } else if i % 5 == 0 {
            print_str("Buzz");
        } else {
            print_int(i);
        }
        i = i + 1;
    }
}
